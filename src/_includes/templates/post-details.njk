<div class="post-details">
  <p>
    {% if author %}
      {% set page = search.page("type=author author='" + author + "'") %}
      {% if page %}
        Par <a data-pagefind-filter="author" href="{{ page.data.url }}">{{ author }}</a> | 
      {% else %}
        Par {{ author }} | 
      {% endif %}
    {% endif %}

    <time datetime="{{ date | date('DATETIME') }}">
      {{ date | date('Europe') }}
    </time>

    {% for tag in tags %}
      {% set page = search.page("type=tag tag='" + tag + "'") %}

      {% if page %}
        | <a data-pagefind-filter="filter" class="tag" href="{{ page.data.url }}">{{ tag }}</a>
      {% endif %}
    {% endfor %}
  </p>
</div>