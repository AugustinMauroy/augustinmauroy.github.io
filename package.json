{
  "dependencies": {
    "@heroicons/react": "~2.2.0",
    "@radix-ui/react-avatar": "~1.1.11",
    "@radix-ui/react-dropdown-menu": "~2.1.16",
    "classnames": "~2.5.1",
    "feed": "~5.2.0",
    "next": "~16.2.2",
    "next-intl": "~4.9.0",
    "next-mdx-remote": "~6.0.0",
    "react": "~19.2.4",
    "react-dom": "~19.2.4",
    "rehype-autolink-headings": "~7.1.0",
    "rehype-mdx-code-props": "~3.0.1",
    "rehype-slug": "~6.0.0",
    "shiki": "~4.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@happy-dom/global-registrator": "^20.8.9",
    "@nodejs-loaders/alias": "~2.1.2",
    "@nodejs-loaders/tsx": "~1.2.0",
    "@storybook/nextjs": "~10.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.2",
    "@types/node": "~25.5.2",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "storybook": "~10.3.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2"
  },
  "scripts": {
    "biome:ci": "biome ci ./",
    "biome:format": "biome format --write ./",
    "biome:lint": "biome lint --write ./",
    "build": "next build",
    "dev": "next dev",
    "postbuild": "node ./scripts/postbuild.js",
    "pre-commit": "node --run biome:format && node --run biome:lint",
    "start": "next start",
    "storybook": "BUILD_ENV=storybook storybook dev -p 6006 --quiet --no-open",
    "storybook:build": "BUILD_ENV=storybook storybook build",
    "test": "node --run test:unit",
    "test:unit": "node --no-warnings --enable-source-maps --import ./node-hooks/react.ts --test **/tests/*.test.tsx **/tests/*.test.ts",
    "test:unit-coverage": "node --no-warnings --import ./node-hooks/react.ts --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=./coverage.lcov --test-reporter=spec --test-reporter-destination=stdout **/tests/*.test.tsx **/tests/*.test.ts",
    "test:watch": "node --no-warnings --enable-source-maps --import ./node-hooks/react.js --test --watch **/tests/*.test.tsx **/tests/*.test.ts",
    "types:check": "tsc --noEmit && echo 'No type errors!'"
  },
  "type": "module"
}
